{
  "name": "emailrpc",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "ci": "turbo run build typecheck test //#oxlint",
    "dev": "turbo run dev --filter=@welcome-text/cli",
    "fmt": "turbo run //#oxfmt",
    "gen": "turbo gen",
    "lint": "turbo run //#oxlint",
    "lint:fix": "turbo run //#oxlint:fix",
    "oxfmt": "oxfmt",
    "oxlint": "oxlint .",
    "oxlint:fix": "oxlint --fix .",
    "release": "turbo run build && changeset publish",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@turbo/gen": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
