{
  "name": "emailrpc",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run //#oxlint",
    "lint:fix": "turbo run //#oxlint:fix",
    "fmt": "turbo run //#oxfmt",
    "oxlint": "oxlint .",
    "oxlint:fix": "oxlint --fix .",
    "oxfmt": "oxfmt",
    "ci": "turbo run build typecheck test //#oxlint",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@vitest/coverage-v8": "^2.1.8",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}