{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "collections/*": ["./.source/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "source.config.ts",
    "vite.config.ts",
    ".source/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
