{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "outputs": [],
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "//#oxlint": {
      "outputs": []
    },
    "//#oxlint:fix": {
      "cache": false
    },
    "//#oxfmt": {
      "cache": false
    }
  }
}
