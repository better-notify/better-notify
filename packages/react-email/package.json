{
  "name": "@emailrpc/react-email",
  "version": "0.1.0",
  "description": "React Email adapter for emailRpc.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "NODE_OPTIONS='--import tsx/esm' rolldown -c",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@emailrpc/core": "workspace:*",
    "@emailrpc/email": "workspace:*"
  },
  "devDependencies": {
    "@internal/rolldown-config": "workspace:*",
    "@internal/tsconfig": "workspace:*",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-email": "6.0.0",
    "rolldown": "1.0.0-rc.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@react-email/components": "^0.0.30",
    "react": "^18.0.0 || ^19.0.0",
    "react-email": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@react-email/components": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
