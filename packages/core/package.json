{
  "name": "@betternotify/core",
  "version": "0.0.3-alpha.0",
  "description": "End-to-end typed email contracts, sender, and webhook router for Node.js.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/better-notify/better-notify",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "default": "./dist/worker.js"
    },
    "./webhook": {
      "types": "./dist/webhook.d.ts",
      "default": "./dist/webhook.js"
    },
    "./transports": {
      "types": "./dist/transports.d.ts",
      "default": "./dist/transports.js"
    },
    "./middlewares": {
      "types": "./dist/middlewares.d.ts",
      "default": "./dist/middlewares.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "default": "./dist/plugins.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./stores": {
      "types": "./dist/stores.d.ts",
      "default": "./dist/stores.js"
    },
    "./sinks": {
      "types": "./dist/sinks.d.ts",
      "default": "./dist/sinks.js"
    },
    "./tracers": {
      "types": "./dist/tracers.d.ts",
      "default": "./dist/tracers.js"
    }
  },
  "scripts": {
    "build": "NODE_OPTIONS='--import tsx/esm' rolldown -c",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@standard-schema/spec": "catalog:"
  },
  "devDependencies": {
    "@internal/rolldown-config": "workspace:*",
    "@internal/tsconfig": "workspace:*",
    "rolldown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
