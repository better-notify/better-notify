{
  "name": "@emailrpc/core",
  "version": "0.1.0",
  "description": "End-to-end typed email contracts, sender, and webhook router for Node.js.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sender": {
      "types": "./dist/sender.d.ts",
      "default": "./dist/sender.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "default": "./dist/worker.js"
    },
    "./webhook": {
      "types": "./dist/webhook.d.ts",
      "default": "./dist/webhook.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "default": "./dist/provider.js"
    },
    "./template": {
      "types": "./dist/template.d.ts",
      "default": "./dist/template.js"
    },
    "./queue": {
      "types": "./dist/queue.d.ts",
      "default": "./dist/queue.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "default": "./dist/test.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    }
  },
  "scripts": {
    "build": "NODE_OPTIONS='--import tsx/esm' rolldown -c",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0"
  },
  "devDependencies": {
    "@internal/rolldown-config": "workspace:*",
    "@internal/tsconfig": "workspace:*",
    "rolldown": "1.0.0-rc.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=22"
  }
}
