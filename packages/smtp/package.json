{
  "name": "@emailrpc/smtp",
  "version": "0.0.1",
  "description": "Nodemailer-backed SMTP transport for emailRpc.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "NODE_OPTIONS='--import tsx/esm' rolldown -c",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emailrpc/core": "workspace:*",
    "@emailrpc/email": "workspace:*",
    "nodemailer": "catalog:"
  },
  "devDependencies": {
    "@internal/rolldown-config": "workspace:*",
    "@internal/tsconfig": "workspace:*",
    "@types/nodemailer": "catalog:",
    "rolldown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
