import { z } from 'zod';
import { emailRpc, type TemplateAdapter } from '@emailrpc/core';

function textTemplate<TInput>(body: (input: TInput) => string): TemplateAdapter<TInput> {
  return {
    render: async (input) => ({ text: body(input) }),
  };
}

const helloInputSchema = z.object({
  name: z.string().min(1),
});

const t = emailRpc.init();

export const emails = t.router({
  hello: t
    .email()
    .input(helloInputSchema)
    .from('hello@example.com')
    .subject(({ input }) => `Hello, ${input.name}!`)
    .template(
      textTemplate<z.infer<typeof helloInputSchema>>(
        ({ name }) => `Hi ${name},\n\nThis is the {{ kebab name }} example.\n`,
      ),
    ),
});

export type EmailRouter = typeof emails;
